<!DOCTYPE html>
<html lang="en">
<head>
    <%-include('../../partials/header.ejs')%>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body  >
    <%-include('../../partials/navbaradmin.ejs')%>
    <div class="container-responsive">
        <div class="conteudo">
            <div class="container">
                <!-- Header de status das reservas (dashboard) -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 header-reservas">
                            <h2 class="fw-bold text-dark mb-3 mb-md-0"><i class="fas fa-tachometer-alt"></i> Visão Geral</h2>
                            <div class="d-flex flex-wrap gap-2 gap-md-3 justify-content-center justify-content-md-end">
                                <div class="stat-card bg-success text-white p-3 rounded shadow">
                                    <i class="fas fa-check-circle fa-2x"></i>
                                    <div class="mt-2">
                                        <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'APROVADO').length %></div>
                                        <small>Aprovadas</small>
                                    </div>
                                </div>
                                <div class="stat-card bg-primary text-white p-3 rounded shadow">
                                    <i class="fas fa-user-clock fa-2x"></i>
                                    <div class="mt-2">
                                        <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'AGUARDANDO_ACEITACAO').length %></div>
                                        <small>Aguardando Aceitação</small>
                                    </div>
                                </div>
                                <div class="stat-card bg-warning text-dark p-3 rounded shadow">
                                    <i class="fas fa-dollar-sign fa-2x"></i>
                                    <div class="mt-2">
                                        <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'AGUARDANDO_PAGAMENTO').length %></div>
                                        <small>Aguardando Pagamento</small>
                                    </div>
                                </div>
                                <div class="stat-card bg-info text-white p-3 rounded shadow">
                                    <i class="fas fa-clock fa-2x"></i>
                                    <div class="mt-2">
                                        <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'ANDAMENTO').length %></div>
                                        <small>Em Andamento</small>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

                <div class="lista-reboques">

                    <%
                        const totalGeral = reboques.reduce((total, r) => {
                            return total + Number(r.total);
                        }, 0);
                    %>

                    <div class="container mt-3">
                        <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                            <!-- Header com Total Geral -->
                            <div class="card-header text-white header-success" style="border: none; padding: 1rem;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-0 fw-bold"><i class="fas fa-chart-line"></i> Receita do Período</h6>
                                        <small>Resumo financeiro</small>
                                    </div>
                                    <div class="text-end">
                                        <div class="fs-4 fw-bold">R$ <%= totalGeral.toFixed(2).replace('.',',') %></div>
                                        <small>Total arrecadado</small>
                                    </div>
                                </div>
                            </div>

                            <!-- Body com Lista de Reboques -->
                            <div class="card-body">
                                <div class="row g-3">
                                    <% reboques.forEach(function(reboque) { %>
                                    <div class="col-12 col-md-6 col-lg-4">
                                        <div class="card border-0 shadow-sm" style="border-radius: 10px; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
                                            <div class="card-body p-3">
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <div class="d-flex align-items-center">
                                                        <div class="avatar-circle bg-success text-white me-3" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.9rem;">
                                                            <i class="fas fa-trailer"></i>
                                                        </div>
                                                        <div>
                                                            <small class="text-muted d-block">Reboque</small>
                                                            <strong class="text-dark"><%= reboque.reboquePlaca %></strong>
                                                        </div>
                                                    </div>
                                                    <div class="text-end">
                                                        <small class="text-muted d-block">Receita</small>
                                                        <strong class="text-success fs-6">R$ <%= Number(reboque.total).toFixed(2).replace('.',',') %></strong>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="container mt-3">
                        <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                            <!-- Header do Gráfico -->
                            <div class="card-header text-white header-info" style="border: none; padding: 1rem;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-0 fw-bold"><i class="fas fa-chart-bar"></i> Análise de Receita</h6>
                                        <small>Receita diária por reboque</small>
                                    </div>
                                    <div class="text-end">
                                        <form class="d-flex align-items-center gap-2" action="painel">
                                            <input class="btn btn-sm btn-outline-light" type="submit" value="Buscar">
                                            <input type="text" placeholder="YYYY-MM" id="competencia" name="competencia" class="form-control form-control-sm" style="max-width: 120px;">
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <!-- Body com o Gráfico -->
                            <div class="card-body">
                                <div style="position: relative; height: 400px; width: 100%;">
                                    <canvas id="myChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <script>
                        const inputCompetencia = document.getElementById('competencia');

                        const hoje = new Date();
                        const ano = hoje.getFullYear();
                        const mes = String(hoje.getMonth() + 1).padStart(2, '0');

                        inputCompetencia.value = `${ano}-${mes}`;
                    </script>



                    <input type="hidden" id="dataJSON" value="<%=dataJSON%>">

                    <!-- Listagem das reservas -->
                    <div class="container mt-3">
                        <div class="card-body">
                            <h5 class="mb-3">📋 Reservas dos Reboques</h5>

                            <div class="row g-3">
                                <% reservas.forEach(function(reserva, i){ 
                                    let nome = reserva.cliente.nome.trim();
                                    let partes = nome.split(/\s+/);
                                    let primeiroNome = partes[0];
                                    let ultimoNome = partes.length > 1 ? partes[partes.length - 1] : "";

                                    let forma = reserva.pagamento.forma || '';
                                    let formaBadge = forma === 'PIX' ? 'bg-primary' : (forma === 'DINHEIRO' ? 'bg-warning text-dark' : 'bg-secondary');

                                    let sit = reserva.situacaoReserva;
                                    let sitLabel = (sit === 'APROVADO' ? 'Aprovado' : (sit === 'ANDAMENTO' ? 'Em andamento' : (sit === 'AGUARDANDO_ACEITACAO' ? 'Aguardando' : sit)));
                                    let sitBadge = (sit === 'APROVADO' ? 'bg-success' : (sit === 'ANDAMENTO' ? 'bg-info' : (sit === 'AGUARDANDO_ACEITACAO' ? 'bg-warning text-dark' : 'bg-secondary')));
                                %>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                                        <!-- Header com Status e Valor -->
                                        <div class="card-header text-white <% if (reserva.situacaoReserva === 'APROVADO') { %>header-aprovado<% } else if (reserva.situacaoReserva === 'CANCELADO') { %>header-cancelado<% } else if (reserva.situacaoReserva === 'ANDAMENTO') { %>header-andamento<% } else if (reserva.situacaoReserva === 'CONCLUIDO') { %>header-concluido<% } else { %>header-default<% } %>" style="border: none; padding: 1rem;">
                                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                                                <div>
                                                    <h6 class="mb-2 fw-bold"><i class="fas fa-calendar-check"></i> Reserva</h6>
                                                    <small>ID: <%=reserva.id%></small>
                                                </div>
                                                <div class="text-end">
                                                    <span class="badge bg-white text-dark fw-bold d-block mb-2"><%= sitLabel %></span>
                                                    <div class="fw-bold">R$ <%= (reserva.pagamento.valor).toFixed(2).replace('.',',') %></div>
                                                    <small><%=reserva.diarias%> dia(s)</small>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Body com Infos Principais -->
                                        <div class="card-body">
                                            <div class="row g-3">
                                                <!-- Cliente -->
                                                <div class="col-12">
                                                    <div class="d-flex align-items-center">
                                                        <div class="avatar-circle bg-primary text-white me-3" style="width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                                            <%= primeiroNome.charAt(0).toUpperCase() %>
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-0 fw-bold text-dark"><%= primeiroNome %> <%= ultimoNome %></h6>
                                                            <small class="text-muted"><i class="fas fa-id-card"></i> <%= reserva.cliente.cpf %></small>
                                                            <br>
                                                            <small class="text-muted"><i class="fas fa-phone"></i> <%= reserva.cliente.telefone %></small>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Reboque -->
                                                <div class="col-12">
                                                    <div class="p-2 bg-light rounded border-start border-success border-4">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <i class="fas fa-trailer text-success me-2"></i>
                                                                <strong class="text-dark"><%= reserva.reboque.placa %></strong>
                                                                <small class="text-muted d-block">Diária: R$ <%= (reserva.pagamento.valor/reserva.diarias).toFixed(2).replace('.',',') %></small>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Período -->
                                                <div class="col-12">
                                                    <div class="p-2 bg-light rounded border-start border-info border-4">
                                                        <div class="row g-2">
                                                            <div class="col-6">
                                                                <small class="text-muted d-block"><i class="fas fa-calendar-day"></i> Saída</small>
                                                                <strong class="text-dark"><%= new Date(reserva.dataSaida).toLocaleDateString('pt-BR') %></strong>
                                                                <small class="text-muted d-block"><%= new Date(reserva.dataSaida).toString().slice(16,18) %>h</small>
                                                            </div>
                                                            <div class="col-6">
                                                                <small class="text-muted d-block"><i class="fas fa-calendar-check"></i> Chegada</small>
                                                                <strong class="text-dark"><%= new Date(reserva.dataChegada).toLocaleDateString('pt-BR') %></strong>
                                                                <small class="text-muted d-block"><%= new Date(reserva.dataChegada).toString().slice(16,18) %>h</small>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Forma de Pagamento -->
                                                <div class="col-12">
                                                    <div class="d-flex justify-content-center">
                                                        <span class="badge <%= formaBadge %> fs-6 px-3 py-2">
                                                            <i class="fas fa-credit-card me-1"></i><%= forma %>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Footer com Ações -->
                                        <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center">
                                            <div>
                                                <% if(reserva.situacaoReserva == 'APROVADO') { %>
                                                    <a href="/reserva/admin/situacao/<%=reserva.id%>/APROVADO" onclick="return confirm('Confirma a operação?')" class="btn btn-sm btn-outline-success">
                                                        <i class="fas fa-play me-1"></i>Iniciar
                                                    </a>
                                                <% } else if (reserva.situacaoReserva == 'ANDAMENTO') { %>
                                                    <a href="/reserva/admin/situacao/<%=reserva.id%>/ANDAMENTO" onclick="return confirm('Confirma a operação?')" class="btn btn-sm btn-outline-danger">
                                                        <i class="fas fa-stop me-1"></i>Encerrar
                                                    </a>
                                                <% } else if(reserva.situacaoReserva == 'AGUARDANDO_ACEITACAO'){ %>
                                                    <form action="/reserva/admin/pagamento/dinheiro" method="POST" class="d-inline">
                                                        <input type="hidden" name="codigoPagamento" value="<%=reserva.pagamento.codigoPagamento%>">
                                                        <input type="hidden" name="valor" value="<%=reserva.pagamento.valor%>">
                                                        <button type="submit" onclick="return confirm('Confirma a operação?')" class="btn btn-sm btn-outline-primary">
                                                            <i class="fas fa-check me-1"></i>Aprovar
                                                        </button>
                                                    </form>
                                                <% } else { %>
                                                    <span class="badge bg-primary"><i class="fas fa-qrcode me-1"></i>PIX</span>
                                                <% } %>
                                            </div>

                                            <a href="/reserva/admin/editar/<%=reserva.id%>" class="btn btn-sm btn-outline-secondary" data-bs-toggle="tooltip" title="Editar reserva">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                            </div>

                            <% if(mensagem && mensagem !== '') { %>
                            <div class="alert alert-danger mt-3">
                                <strong><%= mensagem %></strong>
                            </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Estilo leve para os cards -->
                    <style>
                    .reserva-card{border-radius:1rem;transition:transform .2s ease,box-shadow .2s ease}
                    .reserva-card:hover{transform:translateY(-3px);box-shadow:0 8px 18px rgba(0,0,0,.12)}
                    </style>

                    
                </div>
            </div>
        </div>

        
    </div>

    <script>
        const ctx = document.getElementById('myChart');
        
        let dataJSON = document.getElementById('dataJSON');
        let dataArray = JSON.parse(dataJSON.value);
    
        // Obtém o nome do mês atual e o último dia do mês
        const monthNames = [
            'Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 
            'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'
        ];
        const now = new Date();
        const currentMonth = monthNames[now.getMonth()]; // Nome do mês atual
        const lastDayOfMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate(); // Último dia do mês
    
        // Paleta de cores elegante para os reboques
        const colors = [
            'rgba(54, 162, 235, 0.8)',   // Azul
            'rgba(255, 99, 132, 0.8)',   // Vermelho
            'rgba(255, 205, 86, 0.8)',   // Amarelo
            'rgba(75, 192, 192, 0.8)',   // Verde menta
            'rgba(153, 102, 255, 0.8)',  // Roxo
            'rgba(255, 159, 64, 0.8)',   // Laranja
            'rgba(199, 199, 199, 0.8)',  // Cinza
            'rgba(83, 102, 255, 0.8)',   // Azul escuro
            'rgba(255, 99, 255, 0.8)',   // Rosa
            'rgba(99, 255, 132, 0.8)'    // Verde claro
        ];
    
        const borderColors = [
            'rgba(54, 162, 235, 1)',    // Azul
            'rgba(255, 99, 132, 1)',    // Vermelho
            'rgba(255, 205, 86, 1)',    // Amarelo
            'rgba(75, 192, 192, 1)',    // Verde menta
            'rgba(153, 102, 255, 1)',   // Roxo
            'rgba(255, 159, 64, 1)',    // Laranja
            'rgba(199, 199, 199, 1)',   // Cinza
            'rgba(83, 102, 255, 1)',    // Azul escuro
            'rgba(255, 99, 255, 1)',    // Rosa
            'rgba(99, 255, 132, 1)'     // Verde claro
        ];
    
        new Chart(ctx, {
            type: 'bar', // 🔴 mudou de line para bar
            data: {
                datasets: dataArray.datasets.map((dataset, index) => ({
                    ...dataset,
                    backgroundColor: colors[index % colors.length],
                    borderColor: borderColors[index % borderColors.length],
                    borderWidth: 2,
                    borderRadius: 8,
                    borderSkipped: false,
                })),
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    title: {
                        display: true,
                        text: 'Análise de Receita - Receita Diária por Reboque',
                        font: {
                            size: window.innerWidth < 600 ? 16 : 20,
                            weight: 'bold',
                            family: 'Arial, sans-serif'
                        },
                        color: '#495057',
                        padding: {
                            top: 10,
                            bottom: 30
                        }
                    },
                    legend: {
                        labels: {
                            font: {
                                size: window.innerWidth < 600 ? 10 : 14,
                                family: 'Arial, sans-serif'
                            },
                            color: '#495057',
                            padding: 20,
                            usePointStyle: true,
                            pointStyle: 'rectRounded',
                            generateLabels: function(chart) {
                                const datasets = chart.data.datasets;
                                const labels = chart.data.labels;
                                return datasets.map((dataset, i) => ({
                                    text: dataset.label,
                                    fillStyle: dataset.backgroundColor,
                                    strokeStyle: dataset.borderColor,
                                    lineWidth: dataset.borderWidth,
                                    hidden: !chart.isDatasetVisible(i),
                                    index: i,
                                    pointStyle: 'rectRounded'
                                }));
                            }
                        },
                        position: 'top'
                    },
                    tooltip: {
                        backgroundColor: 'rgba(0, 0, 0, 0.8)',
                        titleColor: '#fff',
                        bodyColor: '#fff',
                        borderColor: '#fff',
                        borderWidth: 1,
                        cornerRadius: 8,
                        displayColors: true,
                        callbacks: {
                            label: function (context) {
                                const ponto = context.raw;
                                const linhas = [];
                                linhas.push(`Valor: R$ ${Number(ponto.y).toFixed(2).replace('.',',')}`);
                                if (ponto.clientes && ponto.clientes.length > 0) {
                                    ponto.clientes.forEach(c => linhas.push(`- ${c}`));
                                }
                                return linhas;
                            }
                        }
                    }

                },
                scales: {
                    x: {
                        type: 'linear',
                        min: 1,
                        max: lastDayOfMonth,
                        ticks: {
                            stepSize: 1,
                            color: '#6c757d',
                            font: {
                                size: 12,
                                family: 'Arial, sans-serif'
                            }
                        },
                        grid: {
                            color: 'rgba(108, 117, 125, 0.1)',
                            borderColor: 'rgba(108, 117, 125, 0.2)'
                        },
                        stacked: true
                    },
                    y: {
                        display: true,
                        stacked: true,
                        ticks: {
                            callback: function(value) {
                                return 'R$ ' + value.toFixed(2).replace('.', ',');
                            },
                            color: '#6c757d',
                            font: {
                                size: 11,
                                family: 'Arial, sans-serif'
                            }
                        },
                        grid: {
                            color: 'rgba(0, 0, 0, 0.1)'
                        }
                    },
                },
                animation: {
                    duration: 2000,
                    easing: 'easeInOutQuart',
                },
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                elements: {
                    bar: {
                        borderRadius: 8,
                        borderSkipped: false,
                    }
                }
            },
        });

    </script>
    
    
    <%-include('../../partials/footer.ejs')%>

</body>
</html>