<!DOCTYPE html>
<html lang="en">
<head>
    <%-include('../../partials/header.ejs')%>
</head>
<body>
  <%-include('../../partials/navbaradmin.ejs')%>
  <div class="conteudo" >

    <div class="container" >

      <!-- Header com Estatísticas Rápidas -->
      <div class="row mb-4">
        <div class="col-12">
          <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 header-reservas">
            <h2 class="fw-bold text-dark mb-3 mb-md-0"><i class="fas fa-list-alt"></i> Lista de Reservas</h2>
            <div class="d-flex flex-wrap gap-2 gap-md-3 justify-content-center justify-content-md-end">
              <div class="stat-card bg-success text-white p-3 rounded shadow">
                <i class="fas fa-check-circle fa-2x"></i>
                <div class="mt-2">
                  <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'APROVADO').length %></div>
                  <small>Aprovadas</small>
                </div>
              </div>
              <div class="stat-card bg-primary text-white p-3 rounded shadow">
                <i class="fas fa-user-clock fa-2x"></i>
                <div class="mt-2">
                  <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'AGUARDANDO_ACEITACAO').length %></div>
                  <small>Aguardando Aceitação</small>
                </div>
              </div>
              <div class="stat-card bg-warning text-dark p-3 rounded shadow">
                <i class="fas fa-dollar-sign fa-2x"></i>
                <div class="mt-2">
                  <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'AGUARDANDO_PAGAMENTO').length %></div>
                  <small>Aguardando Pagamento</small>
                </div>
              </div>
              <div class="stat-card bg-info text-white p-3 rounded shadow">
                <i class="fas fa-clock fa-2x"></i>
                <div class="mt-2">
                  <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'ANDAMENTO').length %></div>
                  <small>Em Andamento</small>
                </div>
              </div>
              <div class="stat-card bg-danger text-white p-3 rounded shadow">
                <i class="fas fa-times-circle fa-2x"></i>
                <div class="mt-2">
                  <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'CANCELADO').length %></div>
                  <small>Canceladas</small>
                </div>
              </div>
              <div class="stat-card bg-secondary text-white p-3 rounded shadow">
                <i class="fas fa-check-double fa-2x"></i>
                <div class="mt-2">
                  <div class="h5 mb-0"><%= reservas.filter(r => r.situacaoReserva === 'CONCLUIDO').length %></div>
                  <small>Concluídas</small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Lista de Reservas -->
      <div class="row">
        <% reservas.forEach(function (reserva, i) { %>
        <div class="col-12 col-md-6 col-xl-4 mb-4">
          <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
            <!-- Header com Status e Valor -->
            <div class="card-header text-white <% if (reserva.situacaoReserva === 'APROVADO') { %>header-aprovado<% } else if (reserva.situacaoReserva === 'CANCELADO') { %>header-cancelado<% } else if (reserva.situacaoReserva === 'ANDAMENTO') { %>header-andamento<% } else if (reserva.situacaoReserva === 'CONCLUIDO') { %>header-concluido<% } else { %>header-default<% } %>" style="border: none; padding: 1rem;">
              <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                <div>
                  <h6 class="mb-2 fw-bold"><i class="fas fa-calendar-check"></i> Reserva</h6>
                  <small>ID: <%=reserva.id%></small>
                </div>
                <div class="text-end">
                  <span class="badge bg-white text-dark fw-bold d-block mb-2"><%=reserva.situacaoReserva%></span>
                  <div class="fw-bold">R$ <%=reserva.pagamento.valor%>,00</div>
                  <small><%=reserva.diarias%> dia(s)</small>
                </div>
              </div>
            </div>

            <!-- Body com Infos Principais -->
            <div class="card-body">
              <div class="row g-3">
                <!-- Cliente -->
                <div class="col-12">
                  <div class="d-flex align-items-center">
                    <div class="avatar-circle bg-primary text-white me-3" style="width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                      <%=reserva.cliente.nome.charAt(0).toUpperCase()%>
                    </div>
                    <div>
                      <h6 class="mb-0 fw-bold text-dark"><%=reserva.cliente.nome%></h6>
                      <small class="text-muted"><i class="fas fa-id-card"></i> <%=reserva.cliente.cpf%></small>
                      <br>
                      <small class="text-muted"><i class="fas fa-phone"></i> <%=reserva.cliente.telefone%></small>
                    </div>
                  </div>
                </div>

                <!-- Endereço -->
                <div class="col-12">
                  <div class="d-flex align-items-start text-muted">
                    <i class="fas fa-map-marker-alt me-2 mt-1"></i>
                    <small><%=reserva.cliente.logradouro%>, <%=reserva.cliente.numero_da_casa%> - <%=reserva.cliente.localidade%></small>
                  </div>
                </div>

                <!-- Reboque -->
                <div class="col-12">
                  <div class="p-2 bg-light rounded border-start border-success border-4">
                    <div class="d-flex align-items-center justify-content-between">
                      <div>
                        <i class="fas fa-trailer text-success me-2"></i>
                        <strong class="text-dark"><%=reserva.reboque.placa%></strong>
                        <small class="text-muted d-block">Diária: R$ <%=reserva.reboque.valorDiaria%>,00</small>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Período -->
                <div class="col-12">
                  <div class="p-2 bg-light rounded border-start border-info border-4">
                    <div class="row g-2">
                      <div class="col-6">
                        <small class="text-muted d-block"><i class="fas fa-calendar-day"></i> Saída</small>
                        <strong class="text-dark"><%=new Date(reserva.dataSaida).toLocaleDateString('pt-BR')%></strong>
                        <small class="text-muted d-block"><%=new Date(reserva.dataSaida).toString().slice(16,21)+'h'%></small>
                      </div>
                      <div class="col-6">
                        <small class="text-muted d-block"><i class="fas fa-calendar-check"></i> Chegada</small>
                        <strong class="text-dark"><%=new Date(reserva.dataChegada).toLocaleDateString('pt-BR')%></strong>
                        <small class="text-muted d-block"><%=new Date(reserva.dataChegada).toString().slice(16,21)+'h'%></small>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Resumo Financeiro -->
                <div class="col-12">
                  <div class="d-flex justify-content-between align-items-center p-2 bg-light rounded border-start border-warning border-4">
                    <div>
                      <small class="text-muted d-block"><i class="fas fa-clock"></i> Diárias</small>
                      <strong class="text-dark"><%=reserva.diarias%> dia(s)</strong>
                    </div>
                    <div class="text-end">
                      <small class="text-muted d-block"><i class="fas fa-dollar-sign"></i> Valor Total</small>
                      <strong class="text-success fs-6">R$ <%=reserva.pagamento.valor%>,00</strong>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <%
        const maxPaginasVisiveis = 2; // quantas antes/depois da atual
        const inicio = Math.max(1, paginaAtual - maxPaginasVisiveis);
        const fim = Math.min(totalPaginas, paginaAtual + maxPaginasVisiveis);
      %>

      <div class="d-flex justify-content-center mt-4">
        <ul class="pagination flex-wrap justify-content-center">

          <!-- Anterior -->
          <li class="page-item <%= paginaAtual === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= paginaAtual - 1 %>"><</a>
          </li>

          <!-- Primeira página -->
          <% if (inicio > 1) { %>
            <li class="page-item">
              <a class="page-link" href="?page=1">1</a>
            </li>

            <% if (inicio > 2) { %>
              <li class="page-item disabled">
                <span class="page-link">...</span>
              </li>
            <% } %>
          <% } %>

          <!-- Páginas centrais -->
          <% for (let i = inicio; i <= fim; i++) { %>
            <li class="page-item <%= i === paginaAtual ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>"><%= i %></a>
            </li>
          <% } %>

          <!-- Última página -->
          <% if (fim < totalPaginas) { %>
            <% if (fim < totalPaginas - 1) { %>
              <li class="page-item disabled">
                <span class="page-link">...</span>
              </li>
            <% } %>

            <li class="page-item">
              <a class="page-link" href="?page=<%= totalPaginas %>">
                <%= totalPaginas %>
              </a>
            </li>
          <% } %>

          <!-- Próximo -->
          <li class="page-item <%= paginaAtual === totalPaginas ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= paginaAtual + 1 %>">></a>
          </li>

        </ul>
      </div>

      
    </div>
  </div>

  <%-include('../../partials/footer'); %>

</body>
</html>