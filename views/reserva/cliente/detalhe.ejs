<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../partials/header.ejs') %>
</head>
<body>
    <%- include('../../partials/navbar.ejs') %>

    <div class="conteudo">
        <div class="container-fluid py-4">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-10">
                    <!-- Header -->
                    <div class="card shadow-sm mb-4">
                        <div class="card-body text-center py-4">
                            <h1 class="display-5 mb-0">Detalhes da Reserva</h1>
                            <p class="text-muted mt-2">Gerencie sua reserva de reboque</p>
                        </div>
                    </div>

                    <% if (mensagem) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        <%= mensagem %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                    <div class="row">
                        <!-- Informações do Reboque -->
                        <div class="col-12 col-md-6 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="card-title mb-0">
                                        <i class="fas fa-truck me-2"></i>
                                        Reboque
                                    </h5>
                                </div>
                                <div class="card-body text-center">
                                    <% if (reserva.reboque.foto) { %>
                                    <img src="../../../<%= reserva.reboque.foto %>" class="img-fluid rounded mb-3" alt="Foto do reboque" style="max-height: 200px;">
                                    <% } else { %>
                                    <div class="bg-light rounded p-4 mb-3">
                                        <i class="fas fa-image fa-3x text-muted"></i>
                                    </div>
                                    <% } %>
                                    <h6 class="text-primary mb-2"><%= reserva.reboque.modelo %></h6>
                                    <p class="text-muted mb-0"><%= reserva.reboque.descricao %></p>
                                </div>
                            </div>
                        </div>

                        <!-- Detalhes da Reserva -->
                        <div class="col-12 col-md-6 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-header bg-info text-white">
                                    <h5 class="card-title mb-0">
                                        <i class="fas fa-calendar-alt me-2"></i>
                                        Detalhes da Reserva
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <div class="border-start border-primary border-4 ps-3">
                                                <small class="text-muted">PERÍODO</small>
                                                <div class="fw-bold">
                                                    <i class="fas fa-play text-success me-1"></i>
                                                    <%= new Date(reserva.dataSaida).toLocaleDateString('pt-BR') %> às <%= new Date(reserva.dataSaida).toString().slice(16,21) %>
                                                </div>
                                                <div class="fw-bold">
                                                    <i class="fas fa-stop text-danger me-1"></i>
                                                    <%= new Date(reserva.dataChegada).toLocaleDateString('pt-BR') %> às <%= new Date(reserva.dataChegada).toString().slice(16,21) %>
                                                </div>
                                                <small class="text-muted mt-1 d-block">
                                                    <i class="fas fa-clock me-1"></i>
                                                    <%= reserva.diarias %> dias
                                                </small>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="border-start border-success border-4 ps-3">
                                                <small class="text-muted">VALORES</small>
                                                <div class="fw-bold fs-5 text-success">
                                                    <i class="fas fa-dollar-sign me-1"></i>
                                                    R$ <%= ((reserva.valorDiaria * reserva.diarias).toFixed(2)).replace('.', ',') %>
                                                </div>
                                                <small class="text-muted">
                                                    R$ <%= ((reserva.valorDiaria).toFixed(2)).replace('.', ',') %> por diária
                                                </small>
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <div class="border-start border-warning border-4 ps-3">
                                                <small class="text-muted">STATUS</small>
                                                <div class="mt-1">
                                                    <% if (reserva.situacaoReserva === 'APROVADO') { %>
                                                        <span class="badge bg-success fs-6 px-3 py-2">
                                                            <i class="fas fa-check-circle me-1"></i>
                                                            Reservado
                                                        </span>
                                                    <% } else if (reserva.situacaoReserva === 'CANCELADO_COM_CREDITO') { %>
                                                        <span class="badge bg-info fs-6 px-3 py-2">
                                                            <i class="fas fa-coins me-1"></i>
                                                            Crédito Disponível
                                                        </span>
                                                    <% } else if (reserva.situacaoReserva === 'AGUARDANDO_ACEITACAO') { %>
                                                        <span class="badge bg-warning fs-6 px-3 py-2">
                                                            <i class="fas fa-clock me-1"></i>
                                                            Pendente Aprovação
                                                        </span>
                                                    <% } else if (reserva.situacaoReserva === 'AGUARDANDO_PAGAMENTO') { %>
                                                        <span class="badge bg-danger fs-6 px-3 py-2">
                                                            <i class="fas fa-exclamation-triangle me-1"></i>
                                                            Pendente Pagamento
                                                        </span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Ações Disponíveis -->
                    <div class="card shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="card-title mb-0">
                                <i class="fas fa-tools me-2"></i>
                                Ações Disponíveis
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <% if(reserva.situacaoReserva == 'APROVADO' || reserva.situacaoReserva == 'CANCELADO_COM_CREDITO') {%>
                                <div class="col-12 col-sm-6 col-md-3">
                                    <a class="btn btn-outline-primary w-100" href="/reserva/cliente/editar/<%= reserva.id %>">
                                        <i class="fas fa-edit me-2"></i>
                                        <span class="d-block">Alterar Período</span>
                                    </a>
                                </div>
                                <div class="col-12 col-sm-6 col-md-3">
                                    <button class="btn btn-outline-warning w-100" type="button" onclick="alert('Este recurso está indisponível no momento')">
                                        <i class="fas fa-minus me-2"></i>
                                        <span class="d-block">Reduzir Diárias</span>
                                    </button>
                                </div>
                                <% if(!(reserva.situacaoReserva == 'CANCELADO_COM_CREDITO')) { %>
                                <div class="col-12 col-sm-6 col-md-3">
                                    <button id="btn-credito" class="btn btn-outline-info w-100" type="button" onclick="ActionHandler.execute('/creditos-reserva/<%= reserva.id %>/criar', 'Crédito gerado com sucesso!', this)">
                                        <i class="fas fa-coins me-2"></i>
                                        <span class="d-block">Colocar Em Espera</span>
                                    </button>
                                </div>
                                <% } else { %>
                                <div class="col-12 col-sm-6 col-md-3">
                                    <button id="btn-ativar" class="btn btn-outline-success w-100" type="button" onclick="ActionHandler.execute('/creditos-reserva/<%= reserva.id %>/usar', 'Crédito aplicado com sucesso!', this)">
                                        <i class="fas fa-check me-2"></i>
                                        <span class="d-block">Remover da Espera</span>
                                    </button>
                                </div>
                                <% } %>
                                <% } %>
                                <div class="col-12 col-sm-6 col-md-3">
                                    <button class="btn btn-outline-secondary w-100" type="button" onclick="history.back()">
                                        <i class="fas fa-arrow-left me-2"></i>
                                        <span class="d-block">Voltar</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="successModal" class="custom-modal">
        <div class="modal-box">
            <h5 class="modal-title">Sucesso</h5>
            <p id="successModalMessage" class="modal-message"></p>
            <button type="button" class="btn btn-primary" onclick="ModalHandler.closeSuccess(() => window.location.reload())">Entendi</button>
        </div>
    </div>

    <div id="errorModal" class="custom-modal">
        <div class="modal-box">
            <h5 class="modal-title text-danger">Erro</h5>
            <p id="errorModalMessage" class="modal-message"></p>
            <button type="button" class="btn btn-secondary" onclick="ModalHandler.closeError()">Entendi</button>
        </div>
    </div>

    <script src="/js/modal-handler.js"></script>
    <script src="/js/action-handler.js"></script>

    <%- include('../../partials/footer.ejs') %>
</body>
</html>
